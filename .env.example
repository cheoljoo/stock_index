# Copy this file to .env and fill in your values
# Load with: export $(cat .env | xargs)   or use python-dotenv

# FRED API key (무료 발급: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# 한국은행 ECOS API key (무료 발급: https://ecos.bok.or.kr/api/#/DevGuide/DevGuide)
ECOS_API_KEY=your_ecos_api_key_here

# SMTP 비밀번호 (Gmail은 앱 비밀번호 사용 권장)
SMTP_PASSWORD=your_smtp_password_here
